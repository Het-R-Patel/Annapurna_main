<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <title>Signup | AnnaPurna</title>
  <link rel="stylesheet" href="/styles/style.css" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600&display=swap" rel="stylesheet">

</head>

<body class="bg-backgroundcolor ">

  <!-- Button to Open Modal -->
  <button onclick="toggleSignupModal(true)" class="bg-purple-600 text-white px-4 py-2 rounded hover:bg-purple-700">
    Sign Up
  </button>

  <!-- Modal Backdrop -->
  <div id="signupModal" class="fixed inset-0 hidden items-center justify-center bg-black bg-opacity-50 z-50">
    <!-- Modal Box -->
    <div class="bg-white rounded-lg shadow-lg p-6 w-full max-w-2xl relative">

      <!-- Close Button -->
      <button onclick="toggleSignupModal(false)"
        class="absolute top-2 right-3 text-2xl text-gray-500 hover:text-red-600">&times;</button>

      <!-- Modal Heading -->
      <h2 class="text-2xl font-semibold text-purple-700 mb-4">Create an Account</h2>

      <!-- Signup Form -->
      <form class="grid grid-cols-1 md:grid-cols-2 gap-4 text-sm">

        <div class="flex flex-col">
          <label for="fullName" class="mb-1 font-medium text-gray-700">Full Name</label>
          <input type="text" id="fullName" name="fullName" placeholder="Enter Name" class="p-2 border rounded-md" />
        </div>

        <div class="flex flex-col">
          <label for="email" class="mb-1 font-medium text-gray-700">Email</label>
          <input type="email" id="email" name="email" placeholder="you@example.com" class="p-2 border rounded-md" />
        </div>

        <div class="flex flex-col">
          <label for="phone" class="mb-1 font-medium text-gray-700">Phone Number</label>
          <input type="text" id="phone" name="phone" placeholder="1234567890" class="p-2 border rounded-md" />
        </div>

        <div class="flex flex-col">
          <label for="dob" class="mb-1 font-medium text-gray-700">Date of Birth</label>
          <input type="date" id="dob" name="dob" class="p-2 border rounded-md" />
        </div>

        <div class="col-span-1 md:col-span-2 flex flex-col">
          <label for="address" class="mb-1 font-medium text-gray-700">Address</label>
          <input type="text" id="address" name="address" placeholder="Enter your address"
            class="p-2 border rounded-md" />
        </div>

        <div class="flex flex-col">
          <label for="password" class="mb-1 font-medium text-gray-700">Password</label>
          <input type="password" id="password" name="password" placeholder="●●●●●●●●" class="p-2 border rounded-md" />
        </div>

        <div class="flex flex-col">
          <label for="confirmPassword" class="mb-1 font-medium text-gray-700">Confirm Password</label>
          <input type="password" id="confirmPassword" name="confirmPassword" placeholder="●●●●●●●●"
            class="p-2 border rounded-md" />
        </div>

        <!-- Submit Button -->
        <div class="col-span-1 md:col-span-2 mt-2">
          <button type="submit" class="w-full bg-purple-600 text-white py-2 rounded hover:bg-purple-700">
            Sign Up
          </button>
        </div>

        <!-- Footer Link -->
        <p class="col-span-1 md:col-span-2 text-center text-sm text-gray-600 mt-2">
          Already have an account? <a href="#" class="text-purple-600 font-medium hover:underline">Login</a>
        </p>
      </form>
    </div>
  </div>

  <!-- JS to toggle modal -->
  <script>
    function toggleSignupModal(show) {
      const modal = document.getElementById("signupModal");
      if (show) {
        modal.classList.remove("hidden");
        modal.classList.add("flex");
      } else {
        modal.classList.add("hidden");
        modal.classList.remove("flex");
      }
    }
  </script>




