<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Contact-Us</title>
    <link rel="stylesheet" href="/styles/style.css" />
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-backgroundcolor">
    <%- include('partials/navbar.ejs') %>
    <div class="bg-bordercolor text-black p-4 rounded-lg shadow-md max-w-md mx-auto mt-10">
        <h2 class="text-xl font-bold mb-4 flex justify-center">Contact Us</h2>
    <form action="">
        <label for="name">Name:</label><br>
        <input type="text" id="name" name="name" class="w-full bg-cardbg rounded-md h-9"><br><br>
        <label for="email">Email:</label><br>
        <input type="email" id="email" name="email" class="w-full bg-cardbg rounded-md h-9"><br><br>
        <label for="email">Phone:</label><br>
        <input type="number" id="Phone" name="Phone" class="w-full bg-cardbg rounded-md h-9"><br><br>
        <label for="message">Message:</label><br>
        <textarea id="message" name="message" class="w-full bg-cardbg rounded-md"></textarea><br><br>
        <input type="submit" value="Submit" class="bg-red-500 rounded-md shadow-md p-1 text-white hover:bg-red-600 transition duration-300 ease-in-out w-full">
    </form>
</div>
</body>
</html>