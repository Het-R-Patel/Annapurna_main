<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Admin Dashboard | AnnaPurna</title>
  <link rel="stylesheet" href="/styles/style.css" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
  <style>
    body {
        font-family: 'Inter', sans-serif;
    }
    
    /* Custom Scrollbar for inner containers */
    .custom-scrollbar::-webkit-scrollbar {
        width: 6px;
    }
    .custom-scrollbar::-webkit-scrollbar-track {
        background: rgba(0,0,0,0.05);
        border-radius: 10px;
    }
    .custom-scrollbar::-webkit-scrollbar-thumb {
        background: rgba(0,0,0,0.2);
        border-radius: 10px;
    }
    .custom-scrollbar::-webkit-scrollbar-thumb:hover {
        background: rgba(0,0,0,0.3);
    }
  </style>
</head>

<body class="bg-backgroundcolor min-h-screen text-textcolor flex font-sans">

  <!-- Sidebar -->
  <aside class="sticky top-0 h-screen w-64 flex-shrink-0 bg-bordercolor p-6 z-40 flex-col justify-between hidden md:flex text-black">
      <div>
        <div class="bg-[#028476] text-white font-bold text-[1.1rem] rounded-xl px-4 py-3 flex items-center gap-3 mb-10 mt-2 shadow-sm">
            <svg xmlns="http://www.w3.org/2000/svg" height="24" width="24" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z" />
            </svg>
            <span class="truncate"><%= user.fullName || "Admin" %></span>
        </div>

        <nav class="space-y-6 text-[1.15rem] font-bold px-1 tracking-wide mt-10" >
            <p onclick="showTab('overview')" class="flex cursor-pointer items-center gap-4 transition-all hover:opacity-75">
              <svg xmlns="http://www.w3.org/2000/svg" height="22" width="22" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M3 13h8V3H3v10zm0 8h8v-6H3v6zM13 3v6h8V3h-8zm0 18h8v-10h-8v10z" />
              </svg>
              Overview
            </p>
            
            <p onclick="showTab('deliveries')" class="flex cursor-pointer items-center gap-4 transition-all hover:opacity-75">
              <svg xmlns="http://www.w3.org/2000/svg" height="22" width="22" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M21 16v-2l-8-5V3.5c0-.83-.67-1.5-1.5-1.5S10 2.67 10 3.5V9l-8 5v2l8-2.5V19l-2 1.5V22l3.5-1 3.5 1v-1.5L13 19v-5.5l8 2.5z"/>
              </svg>
              Deliveries
            </p>

            <p onclick="showTab('donors')" class="flex cursor-pointer items-center gap-4 transition-all hover:opacity-75">
              <svg xmlns="http://www.w3.org/2000/svg" height="22" width="22" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm8 8c0-2.67-4.04-4-8-4s-8 1.33-8 4v3h16v-3zM9 11c1.66 0 2.99-1.34 2.99-3S10.66 5 9 5C7.34 5 6 6.34 6 8s1.34 3 3 3zm0 8c2.67 0 8.1 1.35 8 4v3H1v-3c0-2.65 5.33-4 8-4z"/>
              </svg>
              Donors
            </p>

            <p onclick="showTab('volunteers')" class="flex cursor-pointer items-center gap-4 transition-all hover:opacity-75">
              <svg xmlns="http://www.w3.org/2000/svg" height="22" width="22" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
              </svg>
              Volunteers
            </p>
        </nav>
      </div>

      <!-- Logout -->
      <div class="px-1 border-t border-black/10 pt-4 mt-auto">
          <a href="/logout" class="flex w-full cursor-pointer items-center gap-4 text-black hover:opacity-75 font-bold text-[1.15rem] transition-all">
            <svg xmlns="http://www.w3.org/2000/svg" height="22" width="22" viewBox="0 -960 960 960" fill="currentColor">
              <path d="M200-120q-33 0-56.5-23.5T120-200v-560q0-33 23.5-56.5T200-840h280v80H200v560h280v80H200Zm440-160-55-58 102-102H360v-80h327L585-622l55-58 200 200-200 200Z"/>
            </svg>
            Sign Out
          </a>
      </div>
  </aside>

  <!-- Mobile Top Bar (Only visible on small screens) -->
  <div class="fixed top-0 left-0 w-full bg-bordercolor text-black p-4 flex justify-between items-center z-50 md:hidden shadow-md">
      <h1 class="text-xl font-black">AnnaPurna</h1>
      <a href="/logout" class="bg-black text-white px-4 py-1.5 rounded font-bold text-sm shadow-sm transition-colors">Sign Out</a>
  </div>

  <!-- Main Content -->
  <main class="flex-1 w-full bg-backgroundcolor p-4 md:p-8 lg:p-10 pt-20 md:pt-10 h-screen overflow-y-auto">
    <div class="max-w-7xl mx-auto space-y-8">
        <h2 class="text-3xl font-bold text-white mb-4">Admin Dashboard</h2>

        <% 
            const donorsCount = customers ? customers.length : 0;
            const volunteersCount = volunteers ? volunteers.length : 0;
            const totalDonations = donations ? donations.length : 0;
            const pendingDonations = donations ? donations.filter(d => d.deliverystatus === 'Pending').length : 0;
        %>
        
        <!-- Overview Tab Content -->
        <div id="overview-view" class="space-y-6">
          <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
            <div class="bg-cardbg rounded-2xl p-6 shadow-xl border border-white/40 flex items-center gap-5">
              <div class="bg-[#028476]/10 p-4 rounded-xl text-[#028476]">
                <svg xmlns="http://www.w3.org/2000/svg" height="32" width="32" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.856-1.487M15 10a3 3 0 11-6 0 3 3 0 016 0zM16 20H4v-2a4 4 0 018-0v2" /></svg>
              </div>
              <div>
                <p class="text-sm font-bold text-gray-500 uppercase tracking-wider">Total Donors</p>
                <p class="text-4xl font-black text-[#205781]"><%= donorsCount %></p>
              </div>
            </div>
            
            <div class="bg-cardbg rounded-2xl p-6 shadow-xl border border-white/40 flex items-center gap-5">
              <div style="background-color: rgba(234, 179, 8, 0.1);" class="p-4 rounded-xl text-yellow-600">
                <svg xmlns="http://www.w3.org/2000/svg" height="32" width="32" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M17 20h5v-2a3 3 0 00-5.856-1.487M15 10a3 3 0 11-6 0 3 3 0 016 0zM16 20H4v-2a4 4 0 018 0v2" /></svg>
              </div>
              <div>
                <p class="text-sm font-bold text-gray-500 uppercase tracking-wider">Volunteers</p>
                <p class="text-4xl font-black text-yellow-600"><%= volunteersCount %></p>
              </div>
            </div>

            <div class="bg-cardbg rounded-2xl p-6 shadow-xl border border-white/40 flex items-center gap-5">
              <div style="background-color: rgba(34, 197, 94, 0.1);" class="p-4 rounded-xl text-green-600">
                <svg xmlns="http://www.w3.org/2000/svg" height="32" width="32" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
              </div>
              <div>
                <p class="text-sm font-bold text-gray-500 uppercase tracking-wider">Donations</p>
                <p class="text-4xl font-black text-green-600"><%= totalDonations %></p>
              </div>
            </div>

            <div class="bg-cardbg rounded-2xl p-6 shadow-xl border border-white/40 flex items-center gap-5">
              <div style="background-color: rgba(239, 68, 68, 0.1);" class="p-4 rounded-xl text-red-600">
                <svg xmlns="http://www.w3.org/2000/svg" height="32" width="32" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4v2m0 0v2m0-2h2m0 0h2m-2 0h-2" /></svg>
              </div>
              <div>
                <p class="text-sm font-bold text-gray-500 uppercase tracking-wider">Pending</p>
                <p class="text-4xl font-black text-red-600"><%= pendingDonations %></p>
              </div>
            </div>
          </div>

          <div class="bg-white rounded-2xl p-8 shadow-xl mt-8 flex flex-col md:flex-row items-center justify-between gap-6 border-l-8 border-[#028476]">
             <div class="flex-1">
                 <h3 class="text-3xl font-black text-gray-800 mb-3 tracking-tight">Welcome back, <%= user.fullName || "Admin" %>!</h3>
                 <p class="text-gray-600 text-lg leading-relaxed">You have <strong class="text-[#028476]"><%= donorsCount %> donors</strong> and <strong class="text-[#028476]"><%= volunteersCount %> volunteers</strong>. Keep an eye on the <strong class="text-red-500"><%= pendingDonations %> pending</strong> donations.</p>
             </div>
             <button onclick="showTab('deliveries')" class="bg-[#028476] hover:opacity-90 text-white p-3 rounded-xl font-bold shadow-md transition-all active:scale-95 whitespace-nowrap text-lg">
                View All Deliveries
             </button>
          </div>
        </div>
        
        <!-- Deliveries Tab -->
        <div id="deliveries-view" class="hidden">
          <div class="bg-cardbg rounded-2xl p-6 shadow-xl text-black border border-white/40">
            <h3 class="text-xl font-bold mb-6 text-datelink flex items-center justify-between border-b-2 border-datelink/20 pb-3">
              <span class="flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" height="24" width="24" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 16v-2l-8-5V3.5c0-.83-.67-1.5-1.5-1.5S10 2.67 10 3.5V9l-8 5v2l8-2.5V19l-2 1.5V22l3.5-1 3.5 1v-1.5L13 19v-5.5l8 2.5z" /></svg>
                All Donations
              </span>
              <span class="bg-buttonbg text-textcolor text-sm font-bold px-3 py-1 rounded-full shadow"><%= totalDonations %></span>
            </h3>
            
            <div class="h-[600px] overflow-y-auto pr-3 space-y-4 custom-scrollbar">
              <% if(!donations || donations.length === 0) { %>
                <div class="h-full flex flex-col items-center justify-center text-gray-500">
                  <svg width="64" height="64" class="mb-4 opacity-60 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4"></path></svg>
                  <p class="font-medium text-lg">No donations available.</p>
                </div>
              <% } else { %>
                <% donations.forEach(donation => { %>
                  <div class="bg-white rounded-xl p-5 border border-bordercolor shadow-sm hover:shadow-md transition">
                    <div class="flex justify-between items-start mb-3 border-b pb-2">
                      <h4 class="font-bold text-gray-800 text-lg"><%= donation.foodName %></h4>
                      <span class="<%= donation.deliverystatus === 'Pending' ? 'bg-yellow-100 border border-yellow-300 text-yellow-800' : donation.deliverystatus === 'Delivered' ? 'bg-green-100 border border-green-300 text-green-800' : 'bg-blue-100 border border-blue-300 text-blue-800' %> text-xs font-bold px-2 py-1 rounded shadow-sm"><%= donation.deliverystatus %></span>
                    </div>
                    <div class="text-sm text-gray-700 space-y-2 mb-4 leading-snug">
                      <p><strong class="text-datelink">Type:</strong> <%= donation.foodType %> &nbsp;|&nbsp; <strong class="text-datelink">Qty:</strong> <%= donation.quantity %></p>
                      <p><strong class="text-datelink">Donor:</strong> <%= donation.fullName %></p>
                      <p class="flex flex-col"><strong class="text-datelink">Pickup Location:</strong> <span><%= donation.address %></span></p>
                      <p class="flex flex-col"><strong class="text-datelink">Time:</strong> <span><%= new Date(donation.pickupDate).toLocaleDateString() %> @ <%= donation.preferredPickupTime %></span></p>
                      <% if(donation.volunteerId) { %>
                        <p><strong class="text-datelink">Assigned Volunteer:</strong> <%= donation.volunteerId.fullName %> (<%= donation.volunteerId.phone %>)</p>
                      <% } else { %>
                         <p><strong class="text-datelink">Assigned Volunteer:</strong> <span class="opacity-50 italic">None</span></p>
                      <% } %>
                      <% if(donation.specialInstructions) { %>
                        <p class="text-red-700 bg-red-50 p-2 rounded text-xs border border-red-200"><strong>Notes:</strong> <%= donation.specialInstructions %></p>
                      <% } %>
                    </div>
                  </div>
                <% }) %>
              <% } %>
            </div>
          </div>
        </div>

        <!-- Donors Tab -->
        <div id="donors-view" class="hidden">
          <div class="bg-cardbg rounded-2xl p-6 shadow-xl text-black border border-white/40">
            <h3 class="text-xl font-bold mb-6 text-[#205781] flex items-center justify-between border-b-2 border-[#205781]/20 pb-3">
              <span class="flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" height="24" width="24" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.856-1.487M15 10a3 3 0 11-6 0 3 3 0 016 0zM16 20H4v-2a4 4 0 018 0v2" /></svg>
                Donors List
              </span>
              <span class="bg-navbarbg text-white text-sm font-bold px-3 py-1 rounded-full shadow"><%= donorsCount %></span>
            </h3>
            
            <div class="h-[600px] overflow-y-auto pr-3 space-y-4 custom-scrollbar">
              <% if(!customers || customers.length === 0) { %>
                <div class="h-full flex flex-col items-center justify-center text-gray-500">
                  <svg width="64" height="64" class="mb-4 opacity-60 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"></path></svg>
                  <p class="font-medium text-lg">No donors available.</p>
                </div>
              <% } else { %>
                <% customers.forEach(customer => { %>
                  <div class="bg-white rounded-xl p-5 border border-navbarbg shadow-sm">
                    <div class="flex justify-between items-start mb-3 border-b pb-2">
                      <h4 class="font-bold text-gray-800 text-lg"><%= customer.fullName || customer.name %></h4>
                      <span class="bg-[#205781] text-white text-xs font-bold px-2 py-1 rounded shadow-sm">Donor</span>
                    </div>
                    <div class="text-sm text-gray-700 space-y-2 mb-4 leading-snug">
                      <p><strong class="text-navbarbg font-bold">Email:</strong> <%= customer.email %></p>
                      <p><strong class="text-navbarbg font-bold">Phone:</strong> <%= customer.phone %></p>
                      <p class="flex flex-col"><strong class="text-navbarbg font-bold">Address:</strong> <span><%= customer.address %></span></p>
                    </div>
                  </div>
                <% }) %>
              <% } %>
            </div>
          </div>
        </div>

        <!-- Volunteers Tab -->
        <div id="volunteers-view" class="hidden">
          <div class="bg-cardbg rounded-2xl p-6 shadow-xl text-black border border-white/40">
            <h3 class="text-xl font-bold mb-6 text-[#205781] flex items-center justify-between border-b-2 border-[#205781]/20 pb-3">
              <span class="flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" height="24" width="24" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z" /></svg>
                Volunteers List
              </span>
              <span class="bg-navbarbg text-white text-sm font-bold px-3 py-1 rounded-full shadow"><%= volunteersCount %></span>
            </h3>
            
            <div class="h-[600px] overflow-y-auto pr-3 space-y-4 custom-scrollbar">
              <% if(!volunteers || volunteers.length === 0) { %>
                <div class="h-full flex flex-col items-center justify-center text-gray-500">
                  <svg width="64" height="64" class="mb-4 opacity-60 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                  <p class="font-medium text-lg">No volunteers available.</p>
                </div>
              <% } else { %>
                <% volunteers.forEach(volunteer => { %>
                  <div class="bg-white rounded-xl p-5 border border-green-200 shadow-sm">
                    <div class="flex justify-between items-start mb-3 border-b pb-2">
                      <h4 class="font-bold text-gray-800 text-lg"><%= volunteer.fullName || volunteer.name %></h4>
                      <span class="bg-green-100 text-green-800 text-xs font-bold px-2 py-1 rounded shadow-sm">Volunteer</span>
                    </div>
                    <div class="text-sm text-gray-700 space-y-2 mb-4 leading-snug">
                      <p><strong class="text-navbarbg font-bold">Email:</strong> <%= volunteer.email %></p>
                      <p><strong class="text-navbarbg font-bold">Phone:</strong> <%= volunteer.phone %></p>
                      <p class="flex flex-col"><strong class="text-navbarbg font-bold">Address:</strong> <span><%= volunteer.address %></span></p>
                    </div>
                  </div>
                <% }) %>
              <% } %>
            </div>
          </div>
        </div>

    </div>
  </main>

  <script>
    // Tab switching logic
    function showTab(tabName) {
      document.getElementById('overview-view').classList.add('hidden');
      document.getElementById('deliveries-view').classList.add('hidden');
      document.getElementById('donors-view').classList.add('hidden');
      document.getElementById('volunteers-view').classList.add('hidden');

      if (tabName === 'overview') {
        document.getElementById('overview-view').classList.remove('hidden');
      } else if (tabName === 'deliveries') {
        document.getElementById('deliveries-view').classList.remove('hidden');
      } else if (tabName === 'donors') {
        document.getElementById('donors-view').classList.remove('hidden');
      } else if (tabName === 'volunteers') {
        document.getElementById('volunteers-view').classList.remove('hidden');
      }
    }
  </script>
</body>
</html>