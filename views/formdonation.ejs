<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Annapurna</title>
    <link rel="stylesheet" href="/styles/style.css" type="text/css" />

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Inter', sans-serif;
        }
    </style>
</head>

<body class="bg-backgroundcolor">
    <%- include('partials/navbar.ejs') %>
    <div class="flex items-center justify-center min-h-screen p-4">
    <div class="bg-bordercolor p-6 rounded-lg shadow-lg w-full max-w-4xl">
        <h2 class="text-2xl font-semibold text-center ">Donate Leftover Food</h2>
        <form action="/donate/donateformsubmit" method="POST" class="mt-4 space-y-4 ">
          
            <div>
                <label class="block text-gray-700 font-medium">Full Name</label>
                <input type="text" name="name" value="<%= user.id.name %>" class="w-full bg-cardbg px-4 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-[#E63946]" required>
            </div>
            
            <div>
                <label class="block text-gray-700 font-medium" >Email</label>
                <input type="email" value="<%= user.id.email %>" name="email" class=" w-full bg-cardbg px-4 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-[#E63946]" disabled>
            </div>
            
            <div>
                <label class="block text-gray-700 font-medium">Phone Number</label>
                <input type="tel" name="phone" class="w-full px-4 bg-cardbg py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-[#E63946]" required>
            </div>
            
            <div>
           
                <label class="block text-gray-700 font-medium">House Number</label>
                <input type="text" value="<%= address.houseNo %>" name="houseNo" class="w-full bg-cardbg px-4 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-[#E63946]" required>
                <label class="block text-gray-700 font-medium">Street</label>
                <input type="text" value="<%= address.street %>"  name="street" class="w-full bg-cardbg px-4 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-[#E63946]" required>
                <label class="block text-gray-700 font-medium">City</label>
                <input type="text" value="<%= address.city %>"  name="city" class="w-full bg-cardbg px-4 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-[#E63946]" required>
                <label class="block text-gray-700 font-medium">State</label>
                <input type="text" value="<%= address.state %>"  name="state" class="w-full bg-cardbg px-4 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-[#E63946]" required>
                <label class="block text-gray-700 font-medium">Pincode</label>
                <input type="text" value="<%= address.pincode %>"  name="pincode" class="w-full bg-cardbg px-4 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-[#E63946]" required>
            </div>

            <div>
                <label class="block text-gray-700 font-medium">Food Name</label>
                <input type="text" name="food_name" class="w-full bg-cardbg px-4 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-[#E63946]" required>
            </div>
            
            <div>
                <label class="block text-gray-700 font-medium">Quantity (Servings/Kg)</label>
                <input type="number" name="quantity" class="w-full bg-cardbg px-4 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-[#E63946]" required>
            </div>
            
            <div>
                <label class="block text-gray-700 font-medium">Expiry/Prepared Date</label>
                <input type="date" name="expiry_date" class="w-full bg-cardbg px-4 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-[#E63946]" required>
            </div>
            
            <div>
                <label class="block text-gray-700 font-medium">Food Type</label>
                <select name="food_type" class="w-full bg-cardbg px-4 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-[#E63946]">
                    <option value="veg">Vegetarian</option>
                    <option value="non-veg">Non-Vegetarian</option>
                </select>
            </div>
            
            <div>
                <label class="block text-gray-700 font-medium">Packaging Status</label>
                <select name="packaging_status" class="bg-cardbg w-full px-4 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-[#E63946]">
                    <option value="packaged">Packaged</option>
                    <option value="unpackaged">Unpackaged</option>
                </select>
            </div>
            
            <div>
                <label class="block text-gray-700 font-medium ">Additional Notes</label>
                <textarea name="notes" rows="3" class="w-full px-4 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-[#E63946]"></textarea>
            </div>
            
            <!-- Pickup Information -->
            <div>
                <label class="block text-gray-700 font-medium">Preferred Pickup Time</label>
                <input type="time" name="pickup_time" class="bg-cardbg w-full px-4 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-[#E63946]">
            </div>
            
            
            <div>
                <label class="block text-gray-700 font-medium">Landmark (Optional)</label>
                <input type="text" name="landmark" class="bg-cardbg w-full px-4 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-[#E63946]">
            </div>
            
            <div>
                <label class="block text-gray-700 font-medium">Special Instructions</label>
                <textarea name="instructions" rows="3" class="bg-cardbg w-full px-4 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-[#E63946]"></textarea>
            </div>
            
            <!-- Agreement & Submit -->
            <div class="flex items-center">
                <input type="checkbox" name="agree_terms" class="mr-2 bg-cardbg" required>
                <label class="text-gray-700 font-medium ">I agree to the terms and conditions</label>
            </div>
            
            <button type="submit" class="w-full bg-buttonbg text-white py-2 rounded-lg hover:bg-[#c72d3d] transition">Submit Donation</button>
        </form>
    </div>
</div>
<footer class="bg-[#264653] text-white py-8 mt-6">
    <div class="max-w-6xl mx-auto px-4 grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- About Section -->
        <div>
            <h2 class="text-xl font-semibold">Annapurna</h2>
            <p class="mt-2 text-gray-300">Helping reduce food waste by connecting donors with those in need.</p>
        </div>
        <!-- Quick Links -->
        <div>
            <h2 class="text-xl font-semibold">Quick Links</h2>
            <ul class="mt-2 space-y-2">
                <li><a href="#" class="hover:text-[#F4A261]">Home</a></li>
                <li><a href="#" class="hover:text-[#F4A261]">About Us</a></li>
                <li><a href="#" class="hover:text-[#F4A261]">Donate</a></li>
                <li><a href="#" class="hover:text-[#F4A261]">Contact</a></li>
            </ul>
        </div>
        <!-- Contact Info -->
        <div>
            <h2 class="text-xl font-semibold">Contact Us</h2>
            <p class="mt-2 text-gray-300">Email: support@annapurna.com</p>
            <p class="text-gray-300">Phone: +91 123 456 7890</p>
            <!-- Social Icons -->
            <div class="flex space-x-4 mt-3">
                <a href="#" class="hover:text-[#F4A261]"><i class="fab fa-facebook"></i></a>
                <a href="#" class="hover:text-[#F4A261]"><i class="fab fa-twitter"></i></a>
                <a href="#" class="hover:text-[#F4A261]"><i class="fab fa-instagram"></i></a>
            </div>
        </div>
    </div>
    <div class="text-center mt-6 border-t border-gray-500 pt-4 text-gray-300">
        &copy; 2025 Annapurna. All Rights Reserved.
    </div>
</footer>
</body>

</html>